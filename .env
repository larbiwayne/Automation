# === OPTIONAL: Only needed if you want GPT-4o-mini viral scoring ===
#OPENAI_API_KEY=sk-your-key-here

# === OPTIONAL: AssemblyAI cloud transcription (alternative to Whisper) ===
#ASSEMBLYAI_API_KEY=your-key-here

# === Whisper model size (choose one) ===
# tiny   = 39 MB,  fastest, least accurate
# base   = 74 MB,  fast, decent accuracy
# small  = 244 MB, good balance
# medium = 769 MB, RECOMMENDED (best free balance)
# large-v3 = 3 GB, most accurate, needs 10GB VRAM or slow on CPU
WHISPER_MODEL=medium

# === GPU usage ===
# Set to true ONLY if you have an NVIDIA GPU with CUDA installed
USE_GPU=false

# === Output folder ===
OUTPUT_DIR=D:/clipbot/output

# === Clip settings ===
MIN_CLIP_SECONDS=30
MAX_CLIP_SECONDS=90
CLIPS_PER_VIDEO=3

# === Optional: use local Ollama LLM instead of GPT-4o ===
#USE_LOCAL_LLM=false