import whisper
import os

def generate_subtitles(audio_path: str, output_dir: str) -> str:
    """Transcribe voiceover and generate SRT subtitle file"""
    model = whisper.load_model("base")  # base model runs well on CPU
    result = model.transcribe(audio_path, word_timestamps=True)
    
    srt_path = os.path.join(output_dir, "subtitles.srt")
    
    with open(srt_path, "w", encoding="utf-8") as f:
        for i, segment in enumerate(result["segments"], 1):
            start = format_timestamp(segment["start"])
            end = format_timestamp(segment["end"])
            text = segment["text"].strip()
            f.write(f"{i}\n{start} --> {end}\n{text}\n\n")
    
    print(f"Subtitles saved: {srt_path}")
    return srt_path

def format_timestamp(seconds: float) -> str:
    h = int(seconds // 3600)
    m = int((seconds % 3600) // 60)
    s = int(seconds % 60)
    ms = int((seconds % 1) * 1000)
    return f"{h:02d}:{m:02d}:{s:02d},{ms:03d}"
```

### Step 4: Assemble the final video

```python
import subprocess
import os

def assemble_video(
    clip_paths: list,
    audio_path: str,
    subtitle_path: str,
    music_path: str,
    output_path: str
):
    """
    Concatenate all clips, add voiceover + background music,
    burn subtitles, enforce 9:16 safe zones.
    """
    
    # Step 4a: Create clip list file for FFmpeg concat
    concat_file = "C:\\TikTok_Studio\\temp_concat.txt"
    with open(concat_file, "w") as f:
        for clip in clip_paths:
            f.write(f"file '{clip}'\n")
    
    # Step 4b: Concatenate all clips into one silent video
    raw_video = "C:\\TikTok_Studio\\temp_raw.mp4"
    subprocess.run([
        "ffmpeg", "-y", "-f", "concat", "-safe", "0",
        "-i", concat_file, "-c", "copy", raw_video
    ], check=True, capture_output=True)
    
    # Step 4c: Mix voiceover (100% volume) + background music (12% volume)
    # Subtitle style: large, bold, white with black outline — TikTok optimized
    subtitle_style = (
        "FontName=Arial,FontSize=22,Bold=1,"
        "PrimaryColour=&HFFFFFF,OutlineColour=&H000000,"
        "Outline=3,Shadow=0,Alignment=2,"
        "MarginV=180"  # pushed up from bottom to clear TikTok UI
    )
    
    subprocess.run([
        "ffmpeg", "-y",
        "-i", raw_video,
        "-i", audio_path,
        "-i", music_path,
        "-filter_complex",
        f"[1:a]volume=1.0[voice];[2:a]volume=0.12[music];[voice][music]amix=inputs=2:duration=first[audio];"
        f"[0:v]subtitles={subtitle_path}:force_style='{subtitle_style}'[video]",
        "-map", "[video]",
        "-map", "[audio]",
        "-c:v", "libx264",
        "-preset", "medium",
        "-crf", "20",
        "-c:a", "aac",
        "-b:a", "192k",
        "-shortest",
        output_path
    ], check=True)
    
    print(f"Final video assembled: {output_path}")
    return output_path
```

