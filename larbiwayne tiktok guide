### Step 2: Animate images with Ken Burns effect

This is what makes static images feel cinematic. Each image gets a slow zoom or pan movement matched to the voiceover duration.

Save as `animate_scenes.py`:

```python
import subprocess
import os

def get_audio_duration(audio_path: str) -> float:
    """Get duration of audio file in seconds"""
    result = subprocess.run([
        "ffprobe", "-v", "error", "-show_entries", "format=duration",
        "-of", "default=noprint_wrappers=1:nokey=1", audio_path
    ], capture_output=True, text=True)
    return float(result.stdout.strip())

def animate_scene(image_path: str, output_path: str, duration: float, effect: str = "zoom_in"):
    """
    Apply Ken Burns effect to a single image.
    Effects: zoom_in, zoom_out, pan_right, pan_left, zoom_pan
    """
    
    effects = {
        "zoom_in":   "zoompan=z='min(zoom+0.0008,1.3)':x='iw/2-(iw/zoom/2)':y='ih/2-(ih/zoom/2)'",
        "zoom_out":  "zoompan=z='if(lte(zoom,1.0),1.3,max(1.001,zoom-0.0008))':x='iw/2-(iw/zoom/2)':y='ih/2-(ih/zoom/2)'",
        "pan_right": "zoompan=z='1.2':x='if(lte(on,1),0,x+2)':y='ih/2-(ih/zoom/2)'",
        "pan_left":  "zoompan=z='1.2':x='if(lte(on,1),iw,x-2)':y='ih/2-(ih/zoom/2)'",
        "zoom_pan":  "zoompan=z='min(zoom+0.0006,1.25)':x='iw/2-(iw/zoom/2)+sin(on/30)*20':y='ih/2-(ih/zoom/2)'"
    }
    
    vf = effects.get(effect, effects["zoom_in"])
    frames = int(duration * 30)
    
    cmd = [
        "ffmpeg", "-y",
        "-loop", "1",
        "-i", image_path,
        "-vf", f"{vf},fps=30,scale=1080:1920",
        "-t", str(duration),
        "-c:v", "libx264",
        "-preset", "fast",
        "-crf", "18",
        output_path
    ]
    subprocess.run(cmd, check=True, capture_output=True)
    print(f"Animated: {output_path}")

def animate_all_scenes(image_paths: list, audio_path: str, output_dir: str) -> list:
    """Animate all scenes with varied effects for visual interest"""
    total_duration = get_audio_duration(audio_path)
    scene_duration = total_duration / len(image_paths)
    
    # Alternate effects for visual variety
    effects_sequence = ["zoom_in", "pan_right", "zoom_out", "pan_left", "zoom_pan", "zoom_in"]
    
    clip_paths = []
    for i, image_path in enumerate(image_paths):
        effect = effects_sequence[i % len(effects_sequence)]
        output_path = os.path.join(output_dir, f"clip_{i+1:02d}.mp4")
        animate_scene(image_path, output_path, scene_duration, effect)
        clip_paths.append(output_path)
    
    return clip_paths
```

